# Copy this file to vault.yml, fill in real values, then encrypt it —
# never commit secrets in plaintext:
#
#   cp vault.yml.example vault.yml
#   ansible-vault encrypt vault.yml
#
# Bitbucket Server HTTP access token (Repository read scope is enough —
# this job only reads, it never writes back to Bitbucket).
vault_bitbucket_token: "REPLACE_WITH_BITBUCKET_HTTP_ACCESS_TOKEN"

# DX UIM service account password (paired with dxuim_auth_user, "accountsvcid",
# for HTTP basic auth against the uimapi probe config endpoint).
vault_dxuim_password: "REPLACE_WITH_DXUIM_SERVICE_ACCOUNT_PASSWORD"

# Backstage service-to-service token with permission to call the
# Notifications API on behalf of the sync job.
vault_backstage_token: "REPLACE_WITH_BACKSTAGE_SERVICE_TOKEN"
